# ── Discord ──────────────────────────────────────────────────────────────────
# Token vom Discord Developer Portal: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Rechtsklick auf den Server → "ID kopieren" (Entwicklermodus muss aktiv sein)
GUILD_ID=your_guild_id

# Rollen-IDs (Rechtsklick auf die Rolle in den Servereinstellungen)
MEMBER_ROLE_ID=your_member_role_id
ADMIN_ROLE_ID=your_admin_role_id

# Channel-IDs (Rechtsklick auf den Channel)
WHITELIST_CHANNEL_ID=your_whitelist_channel_id
LOG_CHANNEL_ID=your_log_channel_id

# ── Minecraft RCON ────────────────────────────────────────────────────────────
# PebbleHost: Game Panel → Dein Server → RCON Tab
RCON_HOST=your.server.ip
RCON_PORT=25575
RCON_PASSWORD=your_rcon_password

# ── Minecraft Server (für Status/Query) ──────────────────────────────────────
MC_HOST=your.server.ip
MC_PORT=25565
MC_MAX_PLAYERS=20

# ── Datenbank ─────────────────────────────────────────────────────────────────
DB_PATH=data/bot.db
